# PostgreSQL Database Connection
DATABASE_URL="postgresql://username:password@localhost:5432/documind_db?schema=public"

# NextAuth/Auth.js Configuration
NEXTAUTH_URL="http://localhost:3000"
NEXTAUTH_SECRET="your_nextauth_jwt_signing_secret_key"

# Google OAuth Integration (for Google Sign-In)
GOOGLE_CLIENT_ID="your_google_oauth_client_id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="your_google_oauth_client_secret"

# Large Language Model APIs
OPENAI_API_KEY="sk-proj-your_openai_api_key"
CLAUDE_API_KEY="sk-ant-your_claude_api_key"

# Storage Configuration (UploadThing or AWS S3)
UPLOADTHING_SECRET="sk_live_your_uploadthing_secret"
UPLOADTHING_APP_ID="your_uploadthing_app_id"
AWS_ACCESS_KEY_ID="your_aws_access_key"
AWS_SECRET_ACCESS_KEY="your_aws_secret"
AWS_REGION="us-east-1"
AWS_S3_BUCKET_NAME="documind-uploads"
